# Copy to .env.local and fill in. .env.local is git-ignored — never commit real tokens.

# F1 TV subscription token (JWT) for real-time live timing via F1's SignalR feed.
# Get it from the `login-session` cookie's `subscriptionToken` while logged into F1 TV.
# Optional: without it the app falls back to F1's free static feed / minimizes when nothing is live.
F1_TV_TOKEN=

# Optional: OpenF1 paid API key (alternative real-time source). Leave blank if unused.
OPENF1_API_KEY=

# STRONGLY recommended for any PUBLIC deployment: set this to gate the whole site behind
# HTTP Basic auth (any username; this as the password). Without it, a public URL is open to
# anyone — which can burn your hosting quota and rate-limit the upstream data APIs. Leave
# blank only for local/private use.
DASHBOARD_PASSWORD=
